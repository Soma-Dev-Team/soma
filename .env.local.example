NEXT_PUBLIC_USDA_API_KEY=

# ── AI photo scan (server-side) ─────────────────────────────────────
# OpenRouter unified LLM gateway. One key here powers AI scans for
# every visitor. Get a key at https://openrouter.ai/keys.
OPENROUTER_API_KEY=
# Optional model override. Defaults to google/gemini-2.0-flash-001.
OPENROUTER_MODEL=

# ── Sign-in (all optional; without these the app runs fully local) ──
# Auth.js requires AUTH_SECRET in production. Generate one with:
#   openssl rand -base64 32
AUTH_SECRET=
AUTH_TRUST_HOST=true

# Google OAuth — works on its own (JWT sessions, no DB needed).
# Add http://localhost:3000/api/auth/callback/google AND your prod
# callback URL to the OAuth client in Google Cloud Console.
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Magic-link emails via SMTP (e.g. Brevo, Resend SMTP, Mailgun).
# Requires DATABASE_URL too — Auth.js writes verification tokens.
EMAIL_SERVER_USER=
EMAIL_SERVER_PASSWORD=
EMAIL_FROM=Soma Support Team <som.support.team@gmail.com>

# Neon Postgres connection string (pooled). Required for magic links
# and database sessions. Run `npm run db:migrate` after setting.
DATABASE_URL=

# ── Activity integrations (optional) ────────────────────────────────
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
GARMIN_CLIENT_ID=
GARMIN_CLIENT_SECRET=
WITHINGS_CLIENT_ID=
WITHINGS_CLIENT_SECRET=

NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_GITHUB_URL=
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
